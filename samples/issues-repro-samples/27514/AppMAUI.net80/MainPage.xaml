<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppMAUI.net80.MainPage"
             xmlns:local="clr-namespace:AppMAUI.net80"
             x:DataType="local:ViewModel">
    <CollectionView ItemsSource="{Binding Countries}">
        <CollectionView.ItemsLayout>
            <GridItemsLayout Orientation="Vertical"
                             VerticalItemSpacing="8"
                             HorizontalItemSpacing="8"
                             Span="3" />
        </CollectionView.ItemsLayout>        
        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="local:Country">
                <Grid HeightRequest="80" WidthRequest="80">
                    <Border Margin="8"
                            HeightRequest="80" 
                            WidthRequest="80"
                            VerticalOptions="Center"
                            HorizontalOptions="Center"
                            StrokeThickness="0"
                            BackgroundColor="{StaticResource Gray100}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="40" />
                        </Border.StrokeShape>
                        <Grid RowDefinitions="38, *">
                            <Label Grid.Row="0"
                                   FontSize="28"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center"
                                   Text="{Binding Emoji, Mode=OneTime}"/>
                            <Label Grid.Row="1" 
                                   Margin="4,0" 
                                   Text="{Binding Name, Mode=OneTime}"
                                   HorizontalTextAlignment="Center"
                                   FontSize="12"
                                   MaxLines="2"/>
                        </Grid>
                    </Border>
                </Grid>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>

</ContentPage>
