<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RecipeFinder.Views.RecipeDetailPage"
             Title="Recipe Detail">
    <ScrollView>
        <VerticalStackLayout Padding="20">
            <Image x:Name="RecipeImage"
                   HeightRequest="200"
                   Aspect="AspectFill"
                   HorizontalOptions="Center"
                   Margin="0,0,0,15" />
            
            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,15">
                <Label x:Name="RecipeName"
                       Grid.Column="0"
                       FontSize="24"
                       FontAttributes="Bold" />
                
                <ImageButton x:Name="FavoriteButton"
                            Grid.Column="1"
                            HeightRequest="36"
                            WidthRequest="36"
                            Padding="4"
                            Clicked="FavoriteButton_Clicked" />
            </Grid>
            
            <Label x:Name="RecipeCategory"
                   FontSize="16"
                   TextColor="Gray"
                   Margin="0,0,0,15" />
            
            <Label x:Name="RecipeDescription"
                   Margin="0,0,0,15" />
            
            <Label Text="Ingredients"
                   FontSize="18"
                   FontAttributes="Bold"
                   Margin="0,10,0,5" />
            
            <CollectionView x:Name="IngredientsCollection"
                            HeightRequest="120">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="10,5" 
                                Margin="0,3" 
                                StrokeShape="RoundRectangle 5">
                            <Label Text="{Binding}" />
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
            
            <Label Text="Instructions"
                   FontSize="18"
                   FontAttributes="Bold"
                   Margin="0,15,0,5" />
            
            <CollectionView x:Name="InstructionsCollection"
                            HeightRequest="200">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="Auto,*" Padding="0,3">
                            <Label Grid.Column="0"
                                   Text="{Binding ., StringFormat='Step {0}:'}"
                                   FontAttributes="Bold"
                                   Margin="0,0,10,0" />
                            <Label Grid.Column="1"
                                   Text="{Binding}" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
